# .env.example
# Copy this file to `.env` and replace the placeholder values with your real secrets.
# Do NOT commit the real `.env` file to version control.

DISCORD_TOKEN=your-discord-bot-token-here
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
# Optional: override the image model Kaminiel uses for art requests
GEMINI_IMAGE_MODEL=imagen-3.0-generate

# Optional: identify Kamitchi/Ale so Kaminiel can treat them as her creator
# Provide a comma- or semicolon-separated list of numeric user IDs (enable Discord developer mode to copy IDs)
KAMINIEL_CREATOR_IDS=472963102766399488
# Optional fallback: display/nick names to treat as Kamitchi (case insensitive)
KAMINIEL_CREATOR_NAMES=Kamitchi,Ale

# Optional: adjust Kaminiel's heartbeat messages (minutes, set 0 to disable)
KAMINIEL_HEARTBEAT_MINUTES=5

# --- Kokoro TTS Tweaks (optional) ---
# Kaminiel currently uses Kokoro's American English voices (lang_code='a').
# Pick any of these voice IDs for KOKORO_VOICE (default: af_bella):
#   🇺🇸 Female: af_bella, af_sarah, af_nicole, af_alloy, af_aoede, af_heart,
#              af_jessica, af_kore, af_nova, af_river, af_sky
#   🇺🇸 Male:   am_adam, am_echo, am_eric, am_fenrir, am_liam, am_michael,
#              am_onyx, am_puck, am_santa
#   🇬🇧 Female: bf_alice, bf_emma, bf_isabella, bf_lily
# Other languages exist but require editing `_initialize_kokoro_pipeline`.
KOKORO_VOICE=af_bella
# 1.0 is normal speed/pitch; 1.1 feels slightly brighter.
KOKORO_SPEED=1.1

# Optional: add other environment variables your app may use
# EXAMPLE_OPTION=some-value

# Local LLM fallback (llama-cpp-python)
# Path to your GGUF model file for local fallback
LOCAL_MODEL_PATH=models/Llama-3.2-3B-Instruct-Q4_K_M.gguf

# Legacy fallback (only if you prefer the old variable name)
# GEMINI_KEY=your-gemini-api-key-here
